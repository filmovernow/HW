generator client {
  provider = "prisma-client"

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Author {
  id Int @id @default(autoincrement())
  name String
  bio String?
  books Book[]
}
model Book {
  id Int @id @default(autoincrement())
  title String
  published Boolean @default(false)
  author Author @relation(fields: [authorId], references: [id])
  authorId Int
  categories Category[]
}
model Category {
  id Int @id @default(autoincrement())
  name String @unique
  books Book[]
}